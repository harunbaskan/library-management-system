		"name": "Library Management System",
		"description": "REST API collection for Library Management System.\n\nBase URL: http://localhost:8080\n\nThis collection covers all endpoints for managing books, members, and borrowing operations.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
