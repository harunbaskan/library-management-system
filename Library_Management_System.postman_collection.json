						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"email\": \"john.updated@example.com\",\n    \"phoneNumber\": \"+905559876543\",\n    \"membershipType\": \"PREMIUM\"\n}"
						},
						"url": {
