		},
		{
			"name": "Borrowing",
			"description": "Book borrowing and returning operations",
			"item": [
				{
					"name": "Borrow Book",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"bookId\": 1,\n    \"memberId\": 1,\n    \"notes\": \"First borrow\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/borrows",
							"host": ["{{baseUrl}}"],
							"path": ["api", "borrows"]
						},
						"description": "Creates a new borrow record. Due date is automatically set to 14 days from today. Returns 400 if book is unavailable or member has reached their borrow limit."
					},
					"response": []
