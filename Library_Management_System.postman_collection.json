						"description": "Filters books by genre. Available genres: FICTION, NON_FICTION, SCIENCE, TECHNOLOGY, HISTORY, BIOGRAPHY, FANTASY, MYSTERY, ROMANCE, SELF_HELP, PHILOSOPHY, POETRY, CHILDREN, OTHER"
					},
					"response": []
				},
				{
					"name": "Get Available Books",
					"request": {
						"method": "GET",
						"header": [],
