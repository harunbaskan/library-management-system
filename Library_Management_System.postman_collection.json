					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Clean Code: Updated Edition\",\n    \"author\": \"Robert C. Martin\",\n    \"isbn\": \"9780132350884\",\n    \"publishedDate\": \"2008-08-01\",\n    \"genre\": \"TECHNOLOGY\",\n    \"totalCopies\": 5,\n    \"description\": \"Updated description for the handbook\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/books/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "books", "1"]
						},
						"description": "Updates an existing book. Returns 404 if not found, 409 if new ISBN conflicts."
					},
					"response": []
				},
				{
					"name": "Delete Book",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/books/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "books", "1"]
						},
						"description": "Deletes a book from the catalog. Returns 204 No Content on success."
					},
					"response": []
				},
				{
					"name": "Search Books by Keyword",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/books/search?keyword=clean",
							"host": ["{{baseUrl}}"],
							"path": ["api", "books", "search"],
							"query": [
								{
									"key": "keyword",
									"value": "clean"
								}
							]
						},
						"description": "Searches books by title or author containing the keyword (case-insensitive)."
					},
					"response": []
				},
